# Copie para .env e ajuste os valores (nunca commite o arquivo .env).
# PostgreSQL (user-service)
DB_USER=admin
DB_PASSWORD=admin
POSTGRES_DB=users_db
POSTGRES_PORT=5432

# MongoDB (task-scheduler-service)
MONGO_PORT=27017
MONGO_DATABASE=tasks

# E-mail (notification-service — use senha de app no Gmail)
EMAIL_USERNAME=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app
